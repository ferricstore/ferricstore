<% data = assigns.data %>
<%= page_head("FerricFlow Retention - FerricStore", nil) %>
<body>
  <div class="layout">
    <%= render_sidebar_static("flow_retention") %>
    <main class="main-content">
      <%= render_subpage_header("FerricFlow Retention") %>
      <div class="content">
        <%= render_page_intro("FerricFlow Retention", "Preview and run guarded active-runtime enforcement and terminal workflow cleanup so stuck work and retained data do not grow forever.") %>
        <%= render_flow_subnav("retention") %>
        <%= render_flow_retention_summary(data) %>
        <%= render_flow_retention_controls(data) %>
        <%= render_flow_retention_commands() %>
        <%= render_flow_retention_candidates(data) %>
      </div>
    </main>
  </div>
</body>
</html>
