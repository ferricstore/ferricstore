# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# OS/editor local metadata.
.DS_Store

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
ferricstore-*.tar

# Benchmark HTML reports generated by benchee_html.
/bench/output/

# Runtime data files (created when the server runs).
/data/

# Compiled NIF shared library (built by cargo via mix).
/priv/native/*.so
/priv/native/*.dll
/priv/native/*.dylib

.claude/worktrees/
apps/ferricstore/data/
apps/ferricstore/*.log
apps/ferricstore/priv/native/*.so
apps/ferricstore/priv/native/*.dll
apps/ferricstore/priv/native/*.dylib
apps/ferricstore_server/priv/native/*.so
apps/ferricstore_server/priv/native/*.dll
apps/ferricstore_server/priv/native/*.dylib
apps/ferricstore/priv/patched/*.beam
.claude/
test-results/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
*.tfplan
*.tfvars
*.tfvars.json
.terraform.lock.hcl
apps/ferricstore/native/ferricstore_wal_nif/target/
apps/ferricstore/native/ferricstore_bitcask/target/
apps/ferricstore/native/resp_parser_nif/target/
apps/ferricstore_server/native/resp_parser_nif/target/
*.tfstate.backup
